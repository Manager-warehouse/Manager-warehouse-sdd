server:
  port: ${PORT:8080}
  servlet:
    context-path: /

spring:
  application:
    name: wms-backend

  # Database Configuration (Supabase PostgreSQL)
  datasource:
    url: jdbc:postgresql://aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres?sslmode=require
    username: postgres.jzniugklqehtghgzggiv
    password: YOUR_DATABASE_PASSWORD_HERE 
    driver-class-name: org.postgresql.Driver
    hikari:
      minimum-idle: 5
      maximum-pool-size: 20
      idle-timeout: 30000
      pool-name: WMSHikariCP
      max-lifetime: 2000000
      connection-timeout: 30000

  # JPA & Hibernate Configuration
  jpa:
    database-platform: org.hibernate.dialect.PostgreSQLDialect
    hibernate:
      ddl-auto: validate  # Dùng validate để Flyway quản lý schema, tránh xung đột View
    show-sql: true
    properties:
      hibernate:
        format_sql: true
        jdbc:
          batch_size: 20
        order_inserts: true
        order_updates: true

  # Flyway Database Migration
  flyway:
    enabled: true
    locations: classpath:db/migration
