server:
  port: ${PORT:8080}
  servlet:
    context-path: /

spring:
  application:
    name: wms-backend

  # Database Configuration (Supabase PostgreSQL)
  datasource:
    url: jdbc:postgresql://aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres?sslmode=require
    username: postgres.jzniugklqehtghgzggiv
    password: Warehouse12345se12 
    driver-class-name: org.postgresql.Driver
    hikari:
      minimum-idle: 5
      maximum-pool-size: 20
      idle-timeout: 30000
      pool-name: WMSHikariCP
      max-lifetime: 2000000
      connection-timeout: 30000

  # JPA & Hibernate Configuration
  jpa:
    database-platform: org.hibernate.dialect.PostgreSQLDialect
    hibernate:
      ddl-auto: validate  # Dùng validate để Flyway quản lý schema, tránh xung đột View
    show-sql: true
    properties:
      hibernate:
        format_sql: true
        jdbc:
          batch_size: 20
        order_inserts: true
        order_updates: true

  # Flyway Database Migration
  flyway:
    enabled: true
    locations: classpath:db/migration
    out-of-order: true

  # Mail Configuration
  mail:
    host: smtp.gmail.com
    port: 587
    username: ${MAIL_USERNAME:wms.phucanh@gmail.com}
    password: ${MAIL_PASSWORD:your-app-password}
    properties:
      mail:
        smtp:
          auth: true
          starttls:
            enable: true

# JWT Configuration
jwt:
  secret: ${JWT_SECRET:9a4f2c8d3b7a1e5f8c2d6e0b4a8f9c1d3e7b2a6f0c4d8e2f6a0b4c8d2e6f0a4b}
  access-token-expiry: ${JWT_ACCESS_TOKEN_EXPIRY:900} # 15 minutes (in seconds)
  refresh-token-expiry: ${JWT_REFRESH_TOKEN_EXPIRY:604800} # 7 days (in seconds)

