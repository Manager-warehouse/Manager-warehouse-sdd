#!/bin/sh

set -eu

if [ "$(uname -s)" = "Darwin" ] && [ -x /usr/libexec/java_home ]; then
    JAVA_HOME=$(/usr/libexec/java_home -v 21)
    export JAVA_HOME
    PATH="$JAVA_HOME/bin:$PATH"
    export PATH
fi

if ! java -XshowSettings:properties -version 2>&1 | grep -q "java.specification.version = 21"; then
    echo "WMS backend requires Java 21. Set JAVA_HOME to a JDK 21 installation." >&2
    exit 1
fi

exec mvn "$@"
